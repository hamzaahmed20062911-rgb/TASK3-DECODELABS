# Copy this file to .env and fill in your own values, or just export
# DATABASE_URL directly in your terminal before running the app.

# PostgreSQL connection string (recommended for this project):
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/school_db

# If DATABASE_URL is not set at all, the app automatically falls back to
# a local SQLite file (school.db) so it can still be run without Postgres
# installed - useful for quick local testing.
